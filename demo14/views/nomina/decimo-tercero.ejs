<%- include('../partials/header') %>

<h1>Décimo Tercer Sueldo (Bono Navideño)</h1>

<form class="filter-bar" method="GET" action="/nomina/decimo-tercero">
  <label>Año:</label>
  <input type="number" name="anio" value="<%= anio %>" min="2020" max="2030" class="input" style="width:100px">
  <button type="submit" class="btn btn-secondary">Calcular</button>
</form>

<p class="subtitle">Período: Dic <%= anio - 1 %> - Nov <%= anio %> | Doceava parte de todo lo percibido</p>

<table class="table">
  <thead>
    <tr>
      <th>Empleado</th>
      <th>Período</th>
      <th>Total Percibido</th>
      <th>Días Trabajados</th>
      <th>Valor Décimo Tercero</th>
    </tr>
  </thead>
  <tbody>
    <% detalles.forEach(d => { %>
      <tr>
        <td><%= d.empleado %></td>
        <td><%= d.periodo %></td>
        <td><%= formatMoney(d.total_percibido) %></td>
        <td><%= d.dias_trabajados %></td>
        <td><strong><%= formatMoney(d.valor) %></strong></td>
      </tr>
    <% }) %>
    <tr class="total-row">
      <td colspan="4"><strong>TOTAL</strong></td>
      <td><strong><%= formatMoney(total) %></strong></td>
    </tr>
  </tbody>
</table>

<%- include('../partials/footer') %>
