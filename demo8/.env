# ── Credenciales SMTP (Gmail, Outlook, etc.) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password

# ── Modo de operación ─────────────────────────────────────────
# "dry_run"  → simula el envío, guarda en logs/alertas.log
# "live"     → envía correos reales por SMTP
EMAIL_MODE=dry_run

# ── Scheduler ─────────────────────────────────────────────────
# Hora diaria de ejecución del job (formato 24h)
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0
