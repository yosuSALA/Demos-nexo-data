<%- include('partials/header') %>

<div class="animate-fade-in-up page-header-spaced">
  <h1 class="dev-title">Dashboard<span class="blink-cursor">_</span></h1>
  <p class="subtitle"><%= meses[mes] %> <%= anio %></p>
  <p class="header-quote">"Administrar bien tus recursos es construir hoy el éxito del mañana."</p>
</div>

<div class="cards animate-fade-in-up animate-delay-1">
  <div class="card card-blue">
    <h3><i class="fa-solid fa-users"></i> Empleados Activos</h3>
    <span class="card-number"><%= totalEmpleados %></span>
  </div>
  <div class="card card-green">
    <h3><i class="fa-solid fa-hand-holding-dollar"></i> Costo Nómina</h3>
    <span class="card-number"><%= formatMoney(costoNomina.ingresos) %></span>
    <small>Ingresos brutos del mes</small>
  </div>
  <div class="card card-purple">
    <h3><i class="fa-solid fa-wallet"></i> Neto a Pagar</h3>
    <span class="card-number"><%= formatMoney(costoNomina.neto) %></span>
    <small>Líquido a transferir</small>
  </div>
  <div class="card card-orange">
    <h3><i class="fa-solid fa-landmark"></i> Aporte Patronal</h3>
    <span class="card-number"><%= formatMoney(costoNomina.patronal) %></span>
    <small>IESS patronal del mes</small>
  </div>
</div>

<div class="grid-2 animate-fade-in-up animate-delay-2">
  <div class="panel">
    <h2><i class="fa-solid fa-bell"></i> Alertas</h2>
    <% if (permisosPendientes > 0) { %>
      <div class="alert alert-warning">
        <strong><%= permisosPendientes %></strong> permiso(s) pendiente(s) de aprobación.
        <a href="/permisos">Ver</a>
      </div>
    <% } %>
    <% if (contratosPorVencer.length > 0) { %>
      <div class="alert alert-danger">
        <strong><%= contratosPorVencer.length %></strong> contrato(s) a plazo fijo que requieren atención.
      </div>
      <ul>
        <% contratosPorVencer.forEach(e => { %>
          <li><a href="/empleados/<%= e.id %>"><%= e.apellidos %> <%= e.nombres %></a> - <%= e.cargo %></li>
        <% }) %>
      </ul>
    <% } %>
    <% if (permisosPendientes === 0 && contratosPorVencer.length === 0) { %>
      <p class="text-muted">Sin alertas pendientes.</p>
    <% } %>
  </div>

  <div class="panel">
    <h2><i class="fa-solid fa-bolt"></i> Acciones Rápidas</h2>
    <div class="quick-actions">
      <a href="/empleados/nuevo" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Nuevo Empleado</a>
      <a href="/nomina?mes=<%= mes %>&anio=<%= anio %>" class="btn btn-success"><i class="fa-solid fa-file-invoice-dollar"></i> Ver Nómina</a>
      <a href="/asistencia" class="btn btn-info"><i class="fa-solid fa-clock-rotate-left"></i> Registrar Asistencia</a>
      <a href="/configuracion" class="btn btn-secondary"><i class="fa-solid fa-gear"></i> Configuración</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
